# ═════════════════════════════════════════════════════════════════
#  MAIN MENU
# ═════════════════════════════════════════════════════════════════

MENU = [
    ("1",  "Text / URL QR Code",              "📝", mode_text),
    ("2",  "Wi-Fi QR Code",                   "📶", mode_wifi),
    ("3",  "vCard Contact QR Code",           "👤", mode_vcard),
    ("4",  "UPI Payment QR Code",             "💳", mode_upi),
    ("5",  "SMS QR Code",                     "💬", mode_sms),
    ("6",  "Email QR Code",                   "📧", mode_email),
    ("7",  "Custom Color QR (PNG)",           "🎨", mode_custom_color),
    ("8",  "Save QR as PNG Image",            "💾", mode_save_png),
    ("9",  "Batch Mode (from .txt file)",     "📂", mode_batch),
    ("10", "History Log",                     "🕓", mode_history),
    ("11", "Error Correction Level Selector", "🛡 ", mode_error_level),
    ("12", "Custom Size & Border Control",    "📐", mode_size_border),
    ("13", "QR Info & Details Preview",       "📊", mode_info_preview),
    ("14", "Clipboard Copy",                  "📋", mode_clipboard),
    ("15", "About & Help",                    "ℹ️ ", mode_about),
    ("0",  "Exit",                            "🚪", None),
]

def print_menu_footer():
    """Compact footer line shown at the bottom of every menu screen."""
    print(f"\n  {LGRAY}{DIM}{'─' * 58}{RESET}")
    print(f"  {LGRAY}{DIM}Created & Maintained by{RESET} "
          f"{TEAL}{BOLD}JRD Group Of Companies{RESET}"
          f"  {LGRAY}{DIM}·{RESET}  "
          f"{TEAL}Shaping{RESET}{LGRAY}{DIM} What's Next{RESET}")
    print(f"  {LGRAY}{DIM}{'─' * 58}{RESET}\n")

def main_menu():
    while True:
        clear()
        banner()
        print(f"\n{BOLD}  {'#':<4}  {'Feature':<40}{RESET}")
        print(f"  {DIM}{'─' * 48}{RESET}")
        for key, label, icon, _ in MENU:
            color = RED if key == "0" else CYAN
            print(f"  {color}{BOLD}{key:<4}{RESET}  {icon}  {label}")
        print(f"  {DIM}{'─' * 48}{RESET}")
        print_menu_footer()

        choice = get_input("Enter choice", color=YELLOW).strip()

        matched = False
        for key, label, icon, func in MENU:
            if choice == key:
                matched = True
                if func is None:
                    clear()
                    banner()
                    print(f"\n{GREEN}  👋 Goodbye! Thanks for using QR Generator.{RESET}")
                    footer()
                    sys.exit(0)
                clear()
                banner()
                try:
                    func()
                except KeyboardInterrupt:
                    print(f"\n{YELLOW}↩  Returning to menu…{RESET}")
                pause()
                break

        if not matched:
            print(f"{RED}⚠  Invalid choice '{choice}'. Enter a number from the menu.{RESET}")
            import time; time.sleep(1)

# ═════════════════════════════════════════════════════════════════
#  ENTRY POINT
# ═════════════════════════════════════════════════════════════════
if __name__ == "__main__":
    try:
        main_menu()
    except KeyboardInterrupt:
        print(f"\n\n{YELLOW}⚡ Exiting. Goodbye!{RESET}")
        footer()
        sys.exit(0)
